# Copia questo file come `.env.local` e incolla i valori dal progetto Supabase:
# Dashboard → Settings → API → Project URL e anon (public) key

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Geocoding negozio (Nominatim): User-Agent identificabile con contatto (email o URL). Obbligatorio in produzione.
GEOCODING_USER_AGENT=DintorniMVP/1.0 (mailto:tu@esempio.it)

# URL pubblico dell'app (senza slash finale). Usato nei link email e nelle notifiche push.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server: chiave service role (Dashboard → Settings → API → service_role). Non esporre al client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Segreto condiviso tra Supabase Database Webhook e questa app (stringa lunga casuale).
# Nel webhook: Header Authorization: Bearer <stesso valore>
MESSAGGIO_WEBHOOK_SECRET=genera-una-stringa-lunga-casuale

# Resend (email transazionali)
RESEND_API_KEY=re_xxxx
# Mittente verificato su Resend; in prova si può usare onboarding@resend.dev
RESEND_FROM_EMAIL=Dintorni <onboarding@resend.dev>

# Web Push (VAPID). Genera con: npx web-push generate-vapid-keys
# La chiave pubblica va al client (NEXT_PUBLIC_); la privata solo server (.env.local).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contatto per il provider push (RFC); può essere un mailto: fittizio se non usi un dominio reale
VAPID_MAILTO=mailto:notify@dintorni.app

# --- Push end-to-end (in parole semplici) ---
# 1) In Supabase esegui lo SQL in supabase/notifiche_push_email.sql (tabella push_subscriptions + colonne profilo).
# 2) In Area personale attiva «Notifiche push» e poi «Attiva notifiche su questo dispositivo» (Chrome/Edge).
# 3) Webhook: Supabase → Database → Webhooks → INSERT su public.messaggi → URL .../api/webhooks/notify-message
#    con header Authorization: Bearer <MESSAGGIO_WEBHOOK_SECRET> (stesso valore di qui).
#    Nota: Supabase non può chiamare http://localhost; in locale usa ngrok (o simile) e metti quell'URL nel webhook,
#    oppure prova solo il server con: npm run test:notify-webhook -- <conversazione_id> <mittente_id>
# 4) Deploy: stesse variabili sul hosting; NEXT_PUBLIC_APP_URL deve essere l'URL pubblico del sito.
